# Line-ending policy (ends the CRLF warning wall on Windows).
#
# Everything text is normalized to LF in the repository. Working-tree line
# endings are forced per type below rather than left to core.autocrlf, so
# every contributor and CI runner sees identical bytes.

* text=auto

# Source and config: LF everywhere, including Windows working trees.
# The Linux CI runners, Docker build, and shell scripts all assume LF.
*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.css text eol=lf
*.fxml text eol=lf
*.properties text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Windows-native scripts keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary: never normalize.
*.wav binary
*.png binary
*.jpg binary
*.ico binary
*.icns binary
*.jar binary
